@page
@model IndexModel
@{
    ViewData["Title"] = "Moderne Websites für lokale Unternehmen";
    ViewData["Description"] = "Websites, Hosting-Einrichtung, laufende Betreuung und KI-Chatbots für lokale Unternehmen, Restaurants, Vereine und Dienstleister.";
}

<section class="home-hero" id="start">
    <div class="hero-grid" aria-hidden="true"></div>
    <div class="grain-overlay" aria-hidden="true"></div>

    <div class="home-hero-inner">
        <div class="hero-copy">
            <p class="eyebrow hero-reveal">Webdesign · Hosting-Einrichtung · KI · Betreuung</p>
            <h1 class="hero-title" data-hero-title>
                <span class="hero-line">Moderne Websites für lokale Unternehmen</span>
                <span class="hero-line">— komplett betreut.</span>
            </h1>
            <p class="hero-subtext hero-reveal">Wir erstellen individuelle Websites inklusive Design, technischer Umsetzung, Hosting-Einrichtung und laufender Betreuung. Auf Wunsch auch mit KI-Chatbot.</p>

            <div class="hero-actions hero-reveal">
                <a class="button button-gold button-large" asp-page="/Kontakt">Kostenlos anfragen</a>
                <a class="button button-ghost button-large" asp-page="/Angebote">Angebote ansehen</a>
                <a class="button button-ghost button-large" asp-page="/Portfolio">Beispiele ansehen</a>
            </div>

            <div class="hero-badges hero-reveal" aria-label="Kurzüberblick">
                <span>Design & Umsetzung</span>
                <span>Hosting-Einrichtung</span>
                <span>Monatliche Betreuung</span>
                <span>Optional KI-Chatbot</span>
            </div>
        </div>

        <div class="hero-preview hero-reveal" aria-label="Website-Vorschau">
            <div class="browser-shell">
                <div class="browser-topbar">
                    <span></span><span></span><span></span>
                    <strong>Lokaler Betrieb</strong>
                </div>
                <div class="preview-hero-card">
                    <div>
                        <small>Neue Website</small>
                        <strong>Reservierungen, Leistungen und Anfragen klar an einem Ort.</strong>
                    </div>
                    <a href="#kontakt-preview">Anfragen</a>
                </div>
                <div class="preview-dashboard">
                    <div class="preview-panel large">
                        <span>Website-Abo</span>
                        <strong>Betreuung aktiv</strong>
                        <p>Kleine Änderungen, Wartung und technisches Setup bleiben planbar.</p>
                    </div>
                    <div class="preview-panel">
                        <span>Hosting</span>
                        <strong>extern eingerichtet</strong>
                    </div>
                    <div class="preview-panel">
                        <span>KI-Bot</span>
                        <strong>FAQ bereit</strong>
                    </div>
                </div>
                <div class="chat-bubble">
                    <span>KI</span>
                    <p>Hallo, wie können wir helfen?</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="wide-section" id="leistungen" data-section>
    <div class="section-inner">
        <div class="section-header">
            <div>
                <p class="eyebrow">Leistungen</p>
                <h2>Was wir für lokale Betriebe umsetzen</h2>
            </div>
            <p>Ob Restaurant Website, Handwerker Website, Vereinsseite oder Website-Abo: Wir bauen moderne Websites für kleine Unternehmen, die professionell wirken und technisch sauber betreut werden.</p>
        </div>

        <div class="services-wide-grid">
            @foreach (var service in SiteContent.Services)
            {
                <article class="content-card service-wide-card" data-service-card>
                    <span class="card-kicker">@service.Meta</span>
                    <h3>@service.Title</h3>
                    <p>@service.Text</p>
                    <a class="text-link" href="@service.Link">Mehr erfahren</a>
                </article>
            }
        </div>
    </div>
</section>

<section class="wide-section section-alt" data-section>
    <div class="section-inner split-layout">
        <div>
            <p class="eyebrow">Warum wir</p>
            <h2>Persönlich, modern und ohne Technikstress.</h2>
            <p class="lead">Bernhard und Lukas verbinden direkte Kommunikation mit moderner Entwicklung. Besonders lokale Unternehmen profitieren davon, wenn Website erstellen lassen, Website Betreuung und digitale Lösungen aus einer Hand kommen.</p>
        </div>
        <div class="reason-grid">
            <article class="mini-card">
                <h3>Lokaler Service</h3>
                <p>Persönlicher Kontakt, klare Abstimmung und ein Ansprechpartner statt anonymer Agenturprozesse.</p>
            </article>
            <article class="mini-card">
                <h3>Klare Modelle</h3>
                <p>Website-Abo, Fixpreis-Website, Beratung oder Custom Projekt: Der Umfang wird transparent vereinbart.</p>
            </article>
            <article class="mini-card">
                <h3>Moderne Umsetzung</h3>
                <p>Responsive Layouts, saubere Struktur, SEO-Basics und gute Bedienbarkeit auf Handy, iPad und Desktop.</p>
            </article>
            <article class="mini-card">
                <h3>Passend für KMU</h3>
                <p>Webdesign für kleine Unternehmen, lokale Betriebe, Vereine, Dienstleister und Organisationen.</p>
            </article>
        </div>
    </div>
</section>

<section class="wide-section" id="preise" data-section>
    <div class="section-inner">
        <div class="section-header">
            <div>
                <p class="eyebrow">Preise</p>
                <h2>Kurzer Überblick über unsere Modelle</h2>
            </div>
            <p>Alle Preise sind Richtwerte. Der tatsächliche Preis hängt vom Umfang, gewünschten Funktionen, laufender Betreuung und externen Kosten ab.</p>
        </div>

        <div class="pricing-grid pricing-preview-grid">
            @foreach (var package in SiteContent.PricingPackages)
            {
                <article class="pricing-card @(package.Slug == "business" ? "pricing-card-featured" : "")" data-pricing-card>
                    @if (package.Slug == "business")
                    {
                        <span class="featured-badge">Beliebt für lokale Unternehmen</span>
                    }
                    <div>
                        <p class="pricing-label">@package.Name</p>
                        <h3>@package.MonthlyPrice</h3>
                        <p>@package.AlternativePrice</p>
                    </div>
                    <p>Geeignet für: @package.SuitableFor</p>
                    <ul>
                        @foreach (var item in package.Includes.Take(4))
                        {
                            <li>@item</li>
                        }
                    </ul>
                    <a class="button @(package.Slug == "business" ? "button-gold" : "button-ghost")" asp-page="/Angebote" asp-fragment="@package.Slug">Details ansehen</a>
                </article>
            }
        </div>

        <div class="section-action">
            <a class="button button-gold button-large" asp-page="/Angebote">Zur Angebotsübersicht</a>
        </div>
    </div>
</section>

<section class="wide-section section-alt" id="ablauf" data-section>
    <div class="section-inner">
        <div class="section-header">
            <div>
                <p class="eyebrow">Ablauf</p>
                <h2>Vom Erstkontakt bis zur laufenden Betreuung</h2>
            </div>
            <p>Ein klarer Prozess macht Umfang, Zeitplan und Verantwortlichkeiten verständlich, bevor die Umsetzung beginnt.</p>
        </div>

        <div class="process-grid">
            @foreach (var step in SiteContent.Process)
            {
                <article class="process-step">
                    <span>@step.Number</span>
                    <h3>@step.Title</h3>
                    <p>@step.Text</p>
                </article>
            }
        </div>
    </div>
</section>

<section class="wide-section" data-section>
    <div class="section-inner split-layout platforms-layout">
        <div>
            <p class="eyebrow">Technologie</p>
            <h2>Flexible Umsetzung auf modernen Plattformen</h2>
            <p class="lead">Je nach Projekt richten wir Websites auf passenden Plattformen wie Netlify, Vercel, Cloudflare Pages, Railway oder Hostinger ein. KI-Funktionen können bei Bedarf über APIs wie OpenAI umgesetzt werden.</p>
            <p class="fineprint">Alle genannten Marken gehören den jeweiligen Rechteinhabern. Es besteht keine offizielle Partnerschaft, sofern nicht ausdrücklich angegeben.</p>
        </div>
        <div>
            <p class="platform-heading">Mögliche Hosting- und Technologieplattformen</p>
            <div class="platform-badges">
                @foreach (var platform in SiteContent.Platforms)
                {
                    <span>@platform</span>
                }
            </div>
        </div>
    </div>
</section>

<section class="wide-section section-alt" data-section>
    <div class="section-inner">
        <div class="section-header">
            <div>
                <p class="eyebrow">FAQ</p>
                <h2>Häufige Fragen</h2>
            </div>
            <p>Die wichtigsten Punkte zu Website-Abo, Fixpreis-Projekten, Hosting-Einrichtung, Website Betreuung und KI-Chatbots.</p>
        </div>

        <div class="faq-list">
            @foreach (var faq in SiteContent.FaqItems)
            {
                <details>
                    <summary>@faq.Question</summary>
                    <p>@faq.Answer</p>
                </details>
            }
        </div>
    </div>
</section>

<section class="final-cta" id="kontakt-preview" data-section>
    <div>
        <p class="eyebrow">Unverbindliche Anfrage</p>
        <h2>Lassen Sie uns über Ihre Website sprechen.</h2>
        <p>Schreiben Sie kurz, was Sie brauchen. Wir melden uns mit einer ersten Einschätzung und einem passenden Vorschlag.</p>
        <a class="button button-gold button-large" asp-page="/Kontakt">Unverbindlich anfragen</a>
    </div>
</section>
