@page
@model WebAgentur.Pages.DankeModel
@{
    ViewData["Title"] = "Danke";
    ViewData["TitleKey"] = "meta.thanksTitle";
    ViewData["BodyClass"] = "thanks-page";
}

<section class="thanks-section">
    <div class="thanks-card">
        <svg class="checkmark" viewBox="0 0 120 120" aria-hidden="true">
            <circle cx="60" cy="60" r="52"></circle>
            <path data-check-path d="M36 62l16 16 34-39"></path>
        </svg>
        <p class="eyebrow" data-i18n="thanks.eyebrow">Anfrage gesendet</p>
        <h1 data-i18n="thanks.title">Vielen Dank für Ihre Anfrage.</h1>
        <p data-i18n="thanks.text">Wir melden uns innerhalb von 48 Stunden mit einer ersten Einschätzung bei Ihnen.</p>
        <a class="button button-gold button-large" asp-page="/Index" data-i18n="thanks.button">Zurück zur Startseite</a>
    </div>
</section>
