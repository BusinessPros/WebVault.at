@page "/datenschutz"
@{
    ViewData["Title"] = "Datenschutz";
    ViewData["Description"] = "Datenschutz Platzhalter für [PROJEKTNAME].";
}

<section class="legal-page">
    <div class="legal-content">
        <p class="eyebrow">Rechtliches</p>
        <h1>Datenschutz</h1>

        <div class="legal-card">
            <h2>Platzhalter</h2>
            <p>Die Datenschutzerklärung muss vor Veröffentlichung final geprüft und ergänzt werden.</p>
        </div>

        <div class="legal-card">
            <h2>Zu ergänzende Angaben</h2>
            <p>[DATENSCHUTZ-KONTAKT]</p>
            <p>[HOSTING-ANBIETER]</p>
            <p>[FORMULAR-ANBIETER]</p>
            <p>[KI-ANBIETER, FALLS VERWENDET]</p>
        </div>

        <div class="legal-card">
            <h2>Hinweis</h2>
            <p>Diese Seite ist kein finaler Rechtstext. Rechtlich verbindliche Inhalte müssen vor Veröffentlichung durch die verantwortliche Person oder eine passende Fachstelle geprüft werden.</p>
        </div>
    </div>
</section>
