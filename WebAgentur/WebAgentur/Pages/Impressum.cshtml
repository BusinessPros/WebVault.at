@page "/impressum"
@{
    ViewData["Title"] = "Impressum";
    ViewData["Description"] = "Impressum Platzhalter für [PROJEKTNAME].";
}

<section class="legal-page">
    <div class="legal-content">
        <p class="eyebrow">Rechtliches</p>
        <h1>Impressum</h1>

        <div class="legal-card">
            <h2>Platzhalter</h2>
            <p>Die vollständigen Impressumsdaten werden vor Veröffentlichung durch die verantwortliche Person ergänzt.</p>
        </div>

        <div class="legal-card">
            <h2>[IMPRESSUM-DATEN]</h2>
            <p>[VERANTWORTLICHE PERSON]</p>
            <p>[ADRESSE]</p>
            <p>[KONTAKT]</p>
        </div>

        <div class="legal-card">
            <h2>Hinweis</h2>
            <p>Diese Seite ist kein finaler Rechtstext und muss vor Veröffentlichung geprüft und ergänzt werden.</p>
        </div>
    </div>
</section>
