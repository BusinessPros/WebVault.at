@page "/beratung"
@{
    ViewData["Title"] = "Beratung";
    ViewData["Description"] = "Beratung zu Websites, Domains, Hosting, Website-Struktur, SEO-Basics, Tools und KI-Funktionen.";
}

<section class="page-hero compact-hero">
    <div class="section-inner split-layout">
        <div>
            <p class="eyebrow">Beratung</p>
            <h1>Beratung</h1>
            <p class="lead">Wir helfen bei einfachen Fragen rund um Websites, Domains, Hosting, digitale Tools, Website-Konzepte, SEO-Basics und KI-Funktionen.</p>
            <a class="button button-gold button-large" asp-page="/Kontakt">Beratung anfragen</a>
        </div>
        <div class="notice-card">
            <h2>Termine nach Vereinbarung.</h2>
            <p>Eine kurze Beratung kann helfen, bevor Zeit und Geld in die falsche technische Richtung fließen.</p>
        </div>
    </div>
</section>

<section class="wide-section">
    <div class="section-inner">
        <div class="section-header">
            <div>
                <p class="eyebrow">Themen</p>
                <h2>Wobei wir unterstützen können</h2>
            </div>
            <p>Pragmatische Einschätzung für lokale Unternehmen, Vereine, Dienstleister und Organisationen.</p>
        </div>
        <div class="topic-grid">
            <span>Domain-Auswahl</span>
            <span>Hosting-Plattformen</span>
            <span>Website-Struktur</span>
            <span>SEO-Basics</span>
            <span>Tool-Auswahl</span>
            <span>KI-Integration</span>
            <span>Website-Audit</span>
            <span>technische Einschätzung</span>
        </div>
    </div>
</section>
